---
import Layout from '../layouts/Layout.astro';
---

<Layout title="RoPA Collaborative System | Call Brad">
  <!-- Hero Section -->
  <section class="pt-32 pb-20 lg:pt-40 lg:pb-32 bg-gradient-to-br from-[#2b2e83]/5 via-white to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#2b2e83]/10 rounded-full mb-6">
          <span class="w-2 h-2 bg-[#ed60ed] rounded-full"></span>
          <span class="text-sm font-semibold text-[#2b2e83]">RoPA Collaborative System</span>
        </div>
        <h1 class="font-montserrat text-4xl sm:text-5xl lg:text-6xl font-bold text-[#2b2e83] leading-tight mb-6">
          A RoPA system your team can actually use
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
          A collaborative GDPR workspace built for real operational use. Instead of forcing your team into another heavy compliance platform, the system is designed to make records of processing activities, related assessments, review logic, and follow-up work easier to manage in a structured and practical way.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://app.usemotion.com/meet/javier-kr40/30min-Call-Brad" class="px-8 py-4 bg-[#2b2e83] text-white font-semibold rounded-xl hover:bg-[#232465] transition-all hover:shadow-lg hover:shadow-[#2b2e83]/25">
            Book a demo
          </a>
          <a href="#features" class="px-8 py-4 bg-white text-[#2b2e83] font-semibold rounded-xl border-2 border-[#2b2e83] hover:bg-[#2b2e83]/5 transition-colors">
            Learn more
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-4">
          Why choose our RoPA system?
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Built for businesses that want structure without excessive software overhead.
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8">
        <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
          <div class="w-12 h-12 bg-[#2b2e83] rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Collaborative & easy to maintain</h3>
            <p class="text-gray-600">No more static spreadsheets. Work together in real-time with your team on a purpose-built platform.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
          <div class="w-12 h-12 bg-[#2b2e83] rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Practical GDPR workflows</h3>
            <p class="text-gray-600">Built around real business processes, not enterprise complexity. Focus on what matters.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
          <div class="w-12 h-12 bg-[#2b2e83] rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">No excessive software overhead</h3>
            <p class="text-gray-600">Suitable for businesses that want structure without the bloat of enterprise compliance tools.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
          <div class="w-12 h-12 bg-[#2b2e83] rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Expandable as you grow</h3>
            <p class="text-gray-600">The system grows with your business. Add more processes, jurisdictions, and teams as needed.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-20 lg:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-4">
          How it works
        </h2>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-[#2b2e83] text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">1</div>
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Initial setup</h3>
          <p class="text-gray-600">We help you map your data processing activities and set up the system for your specific needs.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-[#2b2e83] text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">2</div>
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Collaborative workspace</h3>
          <p class="text-gray-600">Your team works together in a shared space, with clear workflows and automated reminders.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-[#2b2e83] text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">3</div>
          <h3 class="font-montserrat text-lg font-bold text-gray-900 mb-2">Ongoing maintenance</h3>
          <p class="text-gray-600">Regular reviews and updates ensure your RoPA stays current as your business evolves.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Preview Image -->
  <!-- <section class="py-20 lg:py-28 bg-white"> -->
  <!--   <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"> -->
  <!--     <div class="text-center mb-12"> -->
  <!--       <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-4"> -->
  <!--         See it in action -->
  <!--       </h2> -->
  <!--     </div> -->
  <!---->
  <!--     <div class="bg-white rounded-2xl shadow-2xl shadow-[#2b2e83]/10 p-6 border border-gray-100 max-w-4xl mx-auto"> -->
  <!--       <div class="rounded-xl overflow-hidden"> -->
  <!--         <img src="/imgs_callbrad/gdpr1.jpg" alt="RoPA Dashboard Preview" class="w-full h-auto" /> -->
  <!--       </div> -->
  <!--     </div> -->
  <!--   </div> -->
  <!-- </section> -->

  <!-- Pricing CTA -->
  <section class="py-20 lg:py-28 bg-gradient-to-b from-[#2b2e83]/10 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-montserrat text-3xl sm:text-4xl font-bold text-[#2b2e83] mb-6">
        Ready to streamline your GDPR compliance?
      </h2>
      <p class="text-lg text-gray-600 mb-8">
        Get in touch to discuss how our RoPA system can work for your business.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://app.usemotion.com/meet/javier-kr40/30min-Call-Brad" class="px-8 py-4 bg-[#2b2e83] text-white font-semibold rounded-xl hover:bg-[#232465] transition-all hover:shadow-lg hover:shadow-[#2b2e83]/25">
          Book a demo
        </a>
        <a href="/" class="px-8 py-4 bg-white text-[#2b2e83] font-semibold rounded-xl border-2 border-[#2b2e83] hover:bg-[#2b2e83]/5 transition-colors">
          Back to home
        </a>
      </div>
    </div>
  </section>
</Layout>
